{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-opencode@3.16.0"],
  "permission": {
    "question": "allow"
  },
  "agent": {
    "ask": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    }
  },
  "mcp": {
    "atlassian": {
      "type": "local",
      "enabled": true,
      "command": ["/opt/homebrew/bin/uvx", "mcp-atlassian"],
      "environment": {
        "CONFLUENCE_URL": "",
        "CONFLUENCE_USERNAME": "",
        "CONFLUENCE_API_TOKEN": ""
      }
    }
  },
  "compaction": {
    "auto": false
  }
}
